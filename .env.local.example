# Anthropic API key — used by the chat route (Process B) to answer questions
# grounded in the lead's site content.
ANTHROPIC_API_KEY=

# Vapi private API key — used only by scripts/build-agent.ts (server-side) to
# create a Vapi assistant for a lead.
VAPI_API_KEY=

# Vapi public key — exposed to the browser (must be prefixed NEXT_PUBLIC_) so
# the VapiWidget can start a voice call from the client.
NEXT_PUBLIC_VAPI_PUBLIC_KEY=

# Optional overrides for scripts/build-agent.ts (defaults to Haiku 4.5). If
# Vapi ever rejects the model string, the script prints Vapi's error body
# naming the currently valid values.
# VAPI_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# VAPI_VOICE_PROVIDER=11labs
# VAPI_VOICE_ID=paula
